{
  "name": "joymaze-content",
  "version": "1.0.0",
  "description": "JoyMaze Content Automation Engine - AI-powered social media content generation",
  "type": "module",
  "scripts": {
    "generate:images": "node scripts/generate-images.mjs",
    "generate:vertex": "node scripts/generate-images-vertex.mjs",
    "generate:captions": "node scripts/generate-captions.mjs",
    "generate:all": "node scripts/generate-images.mjs && node scripts/generate-captions.mjs",
    "publish": "node scripts/generate-captions.mjs && node scripts/post-content.mjs",
    "post": "node scripts/post-content.mjs",
    "post:scheduled": "node scripts/post-content.mjs --scheduled --limit 2",
    "post:scheduled:dry": "node scripts/post-content.mjs --scheduled --limit 2 --dry-run",
    "post:x": "node scripts/post-content.mjs --platform x",
    "post:instagram": "node scripts/post-content.mjs --platform instagram",
    "post:pinterest": "node scripts/post-content.mjs --platform pinterest",
    "post:tiktok": "node scripts/post-content.mjs --platform tiktok",
    "post:youtube": "node scripts/post-content.mjs --platform youtube",
    "cooldown:status": "node -e \"const fs=require('fs');try{const d=JSON.parse(fs.readFileSync('output/posting-cooldown.json'));console.log('Cooldown until:',d.until,'Reason:',d.reason)}catch{console.log('No cooldown active')}\"",
    "cooldown:clear": "node -e \"const fs=require('fs');try{fs.unlinkSync('output/posting-cooldown.json');console.log('Cooldown cleared')}catch{console.log('No cooldown file to clear')}\" && git rm -f --cached output/posting-cooldown.json 2>/dev/null; git commit -m \"chore: clear posting cooldown [skip ci]\" && git push",
    "cooldown:set": "node -e \"const fs=require('fs');const d=process.argv[1];const r=process.argv[2]||'manual';fs.mkdirSync('output',{recursive:true});fs.writeFileSync('output/posting-cooldown.json',JSON.stringify({until:d,reason:r},null,2));console.log('Cooldown set until',d)\" --",
    "calendar": "node scripts/content-calendar.mjs",
    "setup:check": "node scripts/setup-check.mjs",
    "import:raw": "node scripts/import-raw.mjs",
    "generate:prompts": "node scripts/generate-prompts.mjs --save",
    "archive": "node scripts/archive-queue.mjs",
    "daily": "node scripts/archive-queue.mjs && node scripts/collect-analytics.mjs && node scripts/track-output.mjs && node scripts/collect-trends.mjs --monday-only && node scripts/weekly-scorecard.mjs --monday-only --save && node scripts/intelligence-refresh.mjs --monday-only && node scripts/apply-intelligence.mjs --monday-only && node scripts/intelligence-refresh.mjs --competitor-only --monday-only && node scripts/generate-prompts.mjs --save && node scripts/generate-story-ideas.mjs --save && node scripts/generate-asmr-brief.mjs --save && node scripts/generate-challenge-brief.mjs --save && node scripts/generate-x-posts.mjs",
    "weekly": "node scripts/collect-trends.mjs && node scripts/intelligence-refresh.mjs && node scripts/apply-intelligence.mjs && node scripts/intelligence-refresh.mjs --competitor-only",
    "generate:story:ideas": "node scripts/generate-story-ideas.mjs",
    "generate:story:idea": "node scripts/generate-story-ideas.mjs --save",
    "generate:story:idea:long": "node scripts/generate-story-ideas.mjs --slides 10 --save",
    "scheduler": "node scripts/daily-scheduler.mjs",
    "scheduler:now": "node scripts/daily-scheduler.mjs --now",
    "scheduler:post-now": "node scripts/daily-scheduler.mjs --post-now",
    "generate:video": "node scripts/generate-videos.mjs",
    "generate:story": "node scripts/generate-story-video.mjs",
    "generate:story:remotion": "node scripts/generate-story-video.mjs --remotion",
    "generate:story:openai": "node scripts/generate-story-video.mjs --tts openai",
    "generate:story:openai:ws": "node scripts/generate-story-video.mjs --tts openai --word-sync",
    "generate:story:edge": "node scripts/generate-story-video.mjs --tts edge",
    "generate:asmr": "node scripts/generate-asmr-video.mjs",
    "generate:asmr:brief": "node scripts/generate-asmr-brief.mjs --save",
    "brief:challenge": "node scripts/generate-challenge-brief.mjs --save",
    "brief:challenge:dry": "node scripts/generate-challenge-brief.mjs --dry-run",
    "brief:asmr": "node scripts/generate-asmr-brief.mjs --save",
    "brief:asmr:dry": "node scripts/generate-asmr-brief.mjs --dry-run",
    "brief:asmr:wordsearch": "node scripts/generate-asmr-brief.mjs --type wordsearch --save",
    "brief:asmr:maze": "node scripts/generate-asmr-brief.mjs --type maze --save",
    "brief:asmr:coloring": "node scripts/generate-asmr-brief.mjs --type coloring --save",
    "generate:activity:video": "node scripts/generate-activity-video.mjs",
    "generate:activity:video:dry": "node scripts/generate-activity-video.mjs --dry-run",
    "analytics:collect": "node scripts/collect-analytics.mjs",
    "analytics:report": "node scripts/analytics-report.mjs",
    "analytics": "node scripts/collect-analytics.mjs && node scripts/analytics-report.mjs",
    "scorecard": "node scripts/weekly-scorecard.mjs",
    "scorecard:save": "node scripts/weekly-scorecard.mjs --save",
    "trends": "node scripts/collect-trends.mjs",
    "trends:dry": "node scripts/collect-trends.mjs --dry-run",
    "dry-run": "node scripts/generate-images.mjs --dry-run && node scripts/generate-captions.mjs --dry-run",
    "intelligence:refresh": "node scripts/intelligence-refresh.mjs",
    "intelligence:refresh:dry": "node scripts/intelligence-refresh.mjs --dry-run",
    "intelligence:refresh:nocompetitor": "node scripts/intelligence-refresh.mjs --skip-competitor",
    "intelligence:apply": "node scripts/apply-intelligence.mjs",
    "intelligence:apply:dry": "node scripts/apply-intelligence.mjs --dry-run",
    "intelligence:apply:force": "node scripts/apply-intelligence.mjs --force-apply",
    "intelligence:full": "node scripts/intelligence-refresh.mjs && node scripts/apply-intelligence.mjs",
    "intelligence:competitor": "node scripts/intelligence-refresh.mjs --competitor-only",
    "intelligence:competitor:dry": "node scripts/intelligence-refresh.mjs --competitor-only --dry-run",
    "pinterest:refresh": "node scripts/refresh-pinterest-token.mjs",
    "pinterest:refresh:dry": "node scripts/refresh-pinterest-token.mjs --dry-run",
    "x:generate": "node scripts/generate-x-posts.mjs",
    "x:generate:dry": "node scripts/generate-x-posts.mjs --dry-run",
    "x:text:post": "node scripts/post-x-scheduled.mjs",
    "x:text:post:dry": "node scripts/post-x-scheduled.mjs --dry-run",
    "status": "node scripts/status.mjs",
    "brief": "node scripts/generate-brief.mjs",
    "brief:date": "node scripts/generate-brief.mjs",
    "health-check": "node scripts/health-check.mjs",
    "animate:story": "node scripts/render-video.mjs --comp StoryEpisode",
    "animate:story:dry": "node scripts/render-video.mjs --comp StoryEpisode --dry-run",
    "animate:asmr": "node scripts/render-video.mjs --comp AsmrReveal",
    "animate:asmr:dry": "node scripts/render-video.mjs --comp AsmrReveal --dry-run",
    "extract:path": "node scripts/extract-maze-path.mjs",
    "extract:wordsearch": "node scripts/extract-wordsearch-path.mjs",
    "extract:dotdot": "node scripts/extract-dotdot-path.mjs",
    "brief:asmr:dotdot": "node scripts/generate-asmr-brief.mjs --type dotdot --save",
    "animate:hook": "node scripts/render-video.mjs --comp HookIntro",
    "animate:hook:dry": "node scripts/render-video.mjs --comp HookIntro --dry-run",
    "animate:factcard": "node scripts/render-video.mjs --comp AnimatedFactCard",
    "animate:factcard:dry": "node scripts/render-video.mjs --comp AnimatedFactCard --dry-run",
    "animate:challenge": "node scripts/render-video.mjs --comp ActivityChallenge",
    "animate:challenge:dry": "node scripts/render-video.mjs --comp ActivityChallenge --dry-run",
    "animate:preview": "node scripts/render-video.mjs --preview",
    "generate:videos": "node scripts/render-batch.mjs",
    "generate:videos:dry": "node scripts/render-batch.mjs --dry-run",
    "prepend:hook": "node scripts/prepend-hook.mjs",
    "prepend:hook:dry": "node scripts/prepend-hook.mjs --dry-run",
    "animate:asmr:remotion": "node scripts/generate-asmr-video.mjs --remotion",
    "animate:asmr:remotion:dry": "node scripts/generate-asmr-video.mjs --remotion --dry-run",
    "output:track": "node scripts/track-output.mjs",
    "output:report": "node scripts/track-output.mjs --report",
    "generate:longform": "node scripts/generate-longform-brief.mjs",
    "render:longform": "node scripts/render-longform.mjs",
    "render:longform:dry": "node scripts/render-longform.mjs --dry-run",
    "longform:story:plan": "node scripts/generate-story-longform-brief.mjs",
    "longform:story:plan:save": "node scripts/generate-story-longform-brief.mjs --save",
    "longform:story:plan:dry": "node scripts/generate-story-longform-brief.mjs --dry-run",
    "longform:story:narrate": "node scripts/generate-narration.mjs",
    "longform:story:animate": "node scripts/animate-scenes.mjs",
    "longform:story:render": "node scripts/render-story-longform.mjs",
    "longform:story:render:dry": "node scripts/render-story-longform.mjs --dry-run",
    "longform:animal:plan": "node scripts/generate-animal-facts-brief.mjs",
    "longform:animal:plan:save": "node scripts/generate-animal-facts-brief.mjs --save",
    "longform:animal:render": "node scripts/render-story-longform.mjs --format animal",
    "longform:puzzle:compile": "node scripts/generate-puzzle-compilation.mjs",
    "longform:puzzle:render": "node scripts/render-story-longform.mjs --format puzzle-compilation",
    "suno:pool:expand": "node scripts/generate-suno-pool.mjs",
    "suno:pool:expand:dry": "node scripts/generate-suno-pool.mjs --dry-run",
    "longform:setup": "bash scripts/setup/install-coqui.sh",
    "remotion:studio": "npx remotion studio remotion/index.jsx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.0",
    "@remotion/bundler": "^4.0.448",
    "@remotion/renderer": "^4.0.448",
    "dotenv": "^16.4.7",
    "fluent-ffmpeg": "^2.1.3",
    "google-trends-api": "^4.9.2",
    "msedge-tts": "^2.0.4",
    "node-cron": "^3.0.3",
    "openai": "^4.85.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.448",
    "sharp": "^0.33.5",
    "twitter-api-v2": "^1.29.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
